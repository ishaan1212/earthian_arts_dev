{
  "name": "earthian-arts-commerce",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "client:dev": "npm run dev --prefix client",
    "server:dev": "npm run dev --prefix server",
    "build": "npm run build --prefix client",
    "start": "npm run start --prefix server",
    "seed": "npm run seed --prefix server",
    "seed:products": "npm run seed:products --prefix server",
    "lint": "npm run lint --prefix client"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
